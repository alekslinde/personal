---
// No props — mode state lives in the client script
---

<nav class="switcher" aria-label="View mode">
  <button id="btn-human"
    data-mode="human"
    aria-label="Switch to robot mode"
    aria-pressed="false"
    title="Toggle view mode"><span class="toggle-icon">
    <!-- Robot -->
    <svg class="icon-robot" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M0 0h24v24H0z" fill="none" />
      <g fill="currentColor">
        <path d="M4 6h16v2H4zm0 14h16v2H4zM2 8h2v12H2zm18 0h2v12h-2z" />
        <path d="M11 4h2v4h-2zm-3 6h2v2H8zm6 0h4v2h-4zm-1-8h4v2h-4zM0 12h2v2H0zm22 0h2v2h-2zm-12 4h4v2h-4zm-2-2h2v2H8zm6 0h2v2h-2z" />
      </g>
    </svg>
    <!-- Winking face -->
    <svg class="icon-human" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M0 0h24v24H0z" fill="none" />
      <g fill="none">
        <path d="M22 12c0 5.523-4.477 10-10 10S2 17.523 2 12S6.477 2 12 2s10 4.477 10 10" />
        <path stroke="currentColor" stroke-linecap="square" stroke-width="2" d="M22 12c0 5.523-4.477 10-10 10S2 17.523 2 12S6.477 2 12 2s10 4.477 10 10Z" />
        <path stroke="currentColor" stroke-linecap="square" stroke-width="2" d="m16 8.5l-2 1.125V10l2 1.5M8 9v2m.535 4A4 4 0 0 0 12 17c1.48 0 2.773-.804 3.465-2" />
      </g>
    </svg>
  </span></button>
</nav>

<script>
  const btn = document.getElementById('btn-human') as HTMLButtonElement;

  const canvas = document.createElement('canvas');
  Object.assign(canvas.style, {
    position: 'absolute',
    inset: '0',
    width: '100%',
    height: '100%',
    pointerEvents: 'none',
    opacity: '0',
    transition: 'opacity 0.25s',
  });
  btn.style.position = 'relative';
  btn.style.overflow = 'hidden';
  btn.appendChild(canvas);

  const PIXEL = 1, COL_W = 3;

  const SPEED = [1.2, 2.5];
  const C = { bright: '#00cc44', mid: '#00aa33', dim: '#008822' };
  const FADE = 15, SPAWN = 0.45;

  interface Drop { x: number; y: number; age: number; }
  interface Col  { x: number; headY: number; speed: number; drops: Drop[]; }

  let cols: Col[] = [];
  let rafId = 0, active = false;

  btn.addEventListener('mouseenter', () => {
    if (document.body.classList.contains('mode-robot')) return;

    const [sMin, sMax] = SPEED;
    canvas.width  = btn.offsetWidth;
    canvas.height = btn.offsetHeight;
    const n = Math.ceil(canvas.width / COL_W);
    cols = Array.from({ length: n }, (_, i) => ({
      x: i * COL_W + (COL_W - PIXEL) / 2,
      headY: Math.random() * canvas.height,
      speed: sMin + Math.random() * (sMax - sMin),
      drops: [],
    }));

    active = true;
    canvas.style.opacity = '0.6';

    function tick() {
      if (!active) return;
      const ctx = canvas.getContext('2d')!;
      const { width: w, height: h } = canvas;
      ctx.clearRect(0, 0, w, h);

      for (const col of cols) {
        col.headY += col.speed;
        if (col.headY > h) { col.headY = 0; col.speed = sMin + Math.random() * (sMax - sMin); }
        if (Math.random() < SPAWN) col.drops.push({ x: col.x, y: col.headY, age: 0 });
        col.drops = col.drops.filter(d => d.age < FADE);
        for (const d of col.drops) {
          const p = d.age / FADE;
          const color = p < 0.15 ? C.bright : p < 0.4 ? C.mid : C.dim;
          const a = Math.round(Math.max(0, 1 - p) * 255).toString(16).padStart(2, '0');
          ctx.fillStyle = color + a;
          ctx.fillRect(d.x, d.y, PIXEL, PIXEL);
          d.age++;
        }
      }
      rafId = requestAnimationFrame(tick);
    }

    rafId = requestAnimationFrame(tick);
  });

  btn.addEventListener('mouseleave', () => {
    active = false;
    cancelAnimationFrame(rafId);
    canvas.style.opacity = '0';
  });
</script>

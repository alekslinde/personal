---
interface Props {
  linkedin: string;
  github: string;
  labels: { email: string; linkedin: string; github: string };
}
const { linkedin, github, labels } = Astro.props;
---

<div class="contact">
  <!-- email assembled by JS to defeat crawlers -->
  <a href="#" id="email-link" aria-label="Email Aleks Linde">{labels.email}</a>
  <span class="contact-sep">·</span>
  <a href={linkedin} target="_blank" rel="noopener noreferrer" id="li-link" aria-label="Aleks Linde on LinkedIn">{labels.linkedin}</a>
  <span class="contact-sep">·</span>
  <a href={github} target="_blank" rel="noopener noreferrer" id="gh-link" aria-label="Aleks Linde on GitHub">{labels.github}</a>
</div>

<script>
  // Email assembled from char codes only on click — never stored as a string in source
  const u = [105,97,109,97,108,101,120,108,105,110,100,101];
  const d = [103,109,97,105,108,46,99,111,109];
  const el = document.getElementById('email-link') as HTMLAnchorElement;
  if (el) {
    el.addEventListener('click', (ev) => {
      ev.preventDefault();
      window.location.href = 'mailto:' + String.fromCharCode(...u) + '\x40' + String.fromCharCode(...d);
    });
  }
</script>

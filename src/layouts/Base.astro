---
import '../styles/global.scss';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title = 'Aleks Linde — UI Designer & Frontend Developer',
  description = 'UI designer who builds what he designs. Obsessed with the gap between Figma and the browser.',
  ogImage = '/og.png',
  canonicalURL = Astro.url.href,
} = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Aleks Linde" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Aleks Linde" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:creator" content="@iamalexlinde" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=Press+Start+2P&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data (JSON-LD) -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Aleks Linde",
        "url": "https://aleks-linde.github.io",
        "description": "UI designer who builds what he designs. Obsessed with the gap between Figma and the browser.",
        "image": "https://aleks-linde.github.io/og.png",
        "jobTitle": "UI Designer & Frontend Developer",
        "sameAs": [
          "https://www.linkedin.com/in/iamalexlinde",
          "https://github.com/alekslinde"
        ]
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
